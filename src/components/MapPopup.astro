---
export interface Props {
  title: string;
  address: string;
}

const { title, address } = Astro.props;
---

<div class="popup-content min-w-50 p-2">
  <h1 :as="h3" class="text-lg font-semibold text-gray-900 mb-2">
    {title}
  </h1>
  
  <p class="text-sm text-gray-600">
    {address}
  </p>
</div>